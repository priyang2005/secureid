# ══════════════════════════════════════════════════════════════════
# Secure ID — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════

# ── Server ──────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API

SUPABASE_URL=https://htwmwvsiyjjhgjpdqoes.supabase.co

# Anon key: used in frontend (public, safe for browser)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key: used in backend ONLY (keep secret!)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── JWT Session ──────────────────────────────────────────────────
# Secret for signing session tokens. Use a long random string.
# Generate one: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ── AES Encryption ───────────────────────────────────────────────
# Secret used to derive the AES-256 key for QR payload encryption.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=replace_with_another_long_random_string

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (for production)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
